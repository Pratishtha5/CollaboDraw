# Copy this file to .env (ignored) and fill in your own values.
# Never commit real credentials.

## Database config (required)
## Option A (recommended): host/port/db, app builds JDBC URL internally
DB_HOST=your-host.aivencloud.com
DB_PORT=17118
DB_NAME=defaultdb
DB_USER=your_db_user
DB_PASS=your_db_password
SSL_MODE=REQUIRED

## Option B (also supported): AIVEN_* aliases
# AIVEN_HOST=your-host.aivencloud.com
# AIVEN_PORT=17118
# AIVEN_DB=defaultdb

## Google OAuth2 (required by current SecurityConfig)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret